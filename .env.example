# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key (required)
OPENAI_API_KEY=sk-...

# Model selection
LLM_MODEL=gpt-4o-mini          # or gpt-4o for higher quality
EMBEDDING_MODEL=text-embedding-3-small  # openai | all-MiniLM-L6-v2 | Qwen/Qwen3-Embedding-4B

# Embedding backend: "openai" | "local" | "qwen3"
#   openai  → text-embedding-3-small  (1536-dim, API key required)
#   local   → all-MiniLM-L6-v2        (384-dim, no key, fast)
#   qwen3   → Qwen3-Embedding-4B      (2560-dim, no key, ~8 GB VRAM)
EMBEDDING_BACKEND=openai

# RAG settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=4

# Vector store path (auto-created on first ingest)
VECTOR_STORE_PATH=./data/vector_store

# Logging
LOG_LEVEL=INFO
