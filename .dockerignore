models/
checkpoints/
~/.cache/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
tests/

# Logs
*.log
logs/

# Documentation (exclude all .md except README and base docs in docs/)
*.md
!README.md
!docs/Source-*.md

# Exclude session-uploaded docs (have 8-char suffix)
docs/*_[a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9].md

# JSON registries (will be created fresh in container)
data/documents.json
data/pages.json

# CI/CD
.github/
.gitlab-ci.yml

# Jupyter
.ipynb_checkpoints/
*.ipynb
